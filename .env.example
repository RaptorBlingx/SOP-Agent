# ============================================================
# SOP Agent v1.2 — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- LLM Provider Selection ---
# Options: gemini | openai | anthropic | ollama
MODEL_PROVIDER=gemini

# --- Embedding Provider Selection ---
# Options: gemini | openai | ollama
EMBEDDING_PROVIDER=gemini

# --- Gemini (Google AI) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_EMBED_MODEL=models/gemini-embedding-2-preview

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Feature Flags ---
ENABLE_GRAPH_MEMORY=false
ENABLE_PROVIDER_FAILOVER=false
ENABLE_LANGSMITH=false

# --- LangSmith (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sop-agent

# --- Application ---
DATABASE_PATH=./data/sop_agent.db
CHROMADB_PATH=./data/chromadb
UPLOAD_PATH=./data/uploads
LOG_LEVEL=INFO

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=100000
